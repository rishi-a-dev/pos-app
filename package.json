{
  "name": "posapp",
  "version": "1.0.0",
  "main": "index.js",
  "scripts": {
    "start": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "build:android": "eas build --platform android --profile preview",
    "build:ios": "eas build --platform ios --profile preview",
    "build:preview": "eas build --profile preview",
    "submit:android": "eas submit --platform android --latest --profile production",
    "submit:ios": "eas submit --platform ios --latest --profile production",
    "manual-build:android": "cd android && ./gradlew assembleRelease"
  },
  "dependencies": {
    "@gorhom/portal": "^1.0.14",
