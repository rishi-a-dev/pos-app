    "@react-navigation/drawer": "^6.7.0",
    "@react-navigation/native": "^6.1.17",
    "@react-navigation/stack": "^6.4.0",
    "axios": "^1.7.2",
    "expo": "~51.0.39",
    "expo-camera": "~15.0.16",
    "expo-font": "^12.0.7",
    "expo-haptics": "^13.0.1",
    "expo-navigation-bar": "^3.0.7",
    "expo-splash-screen": "~0.27.7",
    "expo-status-bar": "~1.12.1",
    "lottie-react-native": "6.7.0",
    "react": "18.2.0",
